local camera = workspace.CurrentCamera

------------------------------------------------------------------------
-- CONFIGURAÇÕES E ESTRUTURAS DE CACHE
------------------------------------------------------------------------
local ESP = {
    enabled = true,         
    tracersEnabled = true,  
    skeletonEnabled = true, 
    globalColor = Color3.fromRGB(255, 0, 0), -- Vermelho padrão global
    highlights = {}, 
    lines = {}, 
    skeletons = {}, 
    maxDistance = 9999
}

local BoneConnections = {
    {"Head", "UpperTorso"}, {"UpperTorso", "LowerTorso"},
    {"UpperTorso", "LeftUpperArm"}, {"LeftUpperArm", "LeftLowerArm"}, {"LeftLowerArm", "LeftHand"},
    {"UpperTorso", "RightUpperArm"}, {"RightUpperArm", "RightLowerArm"}, {"RightLowerArm", "RightHand"},
    {"LowerTorso", "LeftUpperLeg"}, {"LeftUpperLeg", "LeftLowerLeg"}, {"LeftLowerLeg", "LeftFoot"},
    {"LowerTorso", "RightUpperLeg"}, {"RightUpperLeg", "RightLowerLeg"}, {"RightLowerLeg", "RightFoot"},
    {"Torso", "Left Arm"}, {"Torso", "Right Arm"}, {"Torso", "Left Leg"}, {"Torso", "Right Leg"}, {"Head", "Torso"}
}

-- Cache central de informações dos jogadores para evitar varreduras lineares repetitivas
local PlayerCache = {}

------------------------------------------------------------------------
-- FUNÇÕES DE LIMPEZA E POOLING (Anti-Leak)
------------------------------------------------------------------------
local function clearPlayerVisuals(plr)
    if ESP.highlights[plr] then 
        pcall(function() ESP.highlights[plr]:Destroy() end)
        ESP.highlights[plr] = nil 
    end
    if ESP.lines[plr] then 
        pcall(function() ESP.lines[plr]:Remove() end)
        ESP.lines[plr] = nil 
    end
    if ESP.skeletons[plr] then
        -- Limpa o Object Pool de linhas do desenho
        for _, line in ipairs(ESP.skeletons[plr].Lines) do 
            pcall(function() line:Remove() end) 
        end
        ESP.skeletons[plr] = nil
    end
end

-- Object Pool: Reutiliza instâncias de 'Line' para evitar sobrecarga no Garbage Collector
local function getSkeletonLines(plr, count)
    local cache = ESP.skeletons[plr]
    if not cache then
        cache = { Lines = {}, ActiveCount = 0 }
        ESP.skeletons[plr] = cache
    end
    
    while #cache.Lines < count do
        local line = Drawing.new("Line")
        line.Thickness = 2
        line.Transparency = 0.7
        table.insert(cache.Lines, line)
    end
    return cache.Lines
end

------------------------------------------------------------------------
-- GERENCIAMENTO DE CICLO DE VIDA (Event-Driven)
------------------------------------------------------------------------
local function onCharacterAdded(plr, char)
    clearPlayerVisuals(plr) -- Limpa resíduos anteriores caso existam
    
    local hum = char:WaitForChild("Humanoid", 5)
    local hrp = char:WaitForChild("HumanoidRootPart", 5) or char:WaitForChild("Head", 5)
    
    if hum and hrp then
        PlayerCache[plr] = {
            Character = char,
            Humanoid = hum,
            RootPart = hrp,
            CachedBones = {} -- Evita usar FindFirstChild a cada frame
        }
        
        -- Evento nativo para limpar assim que o personagem morre
        hum.Died:Connect(function()
            clearPlayerVisuals(plr)
        end)
    end
end

local function onPlayerAdded(plr)
    if plr == player then return end
    plr.CharacterAdded:Connect(function(char)
        onCharacterAdded(plr, char)
    end)
    if plr.Character then
        task.spawn(onCharacterAdded, plr, plr.Character)
    end
end

-- Inicializa escutas para quem já está ou vai entrar no servidor
Players.PlayerAdded:Connect(onPlayerAdded)
for _, plr in ipairs(Players:GetPlayers()) do
    onPlayerAdded(plr)
end

Players.PlayerRemoving:Connect(function(plr)
    clearPlayerVisuals(plr)
    PlayerCache[plr] = nil
end)

------------------------------------------------------------------------
-- LOOP DE RENDERIZAÇÃO OTIMIZADO (RenderStepped)
------------------------------------------------------------------------
RunService.RenderStepped:Connect(function()
    local anyVisualEnabled = ESP.enabled or ESP.tracersEnabled or ESP.skeletonEnabled
    if not anyVisualEnabled then
        for plr, _ in pairs(PlayerCache) do clearPlayerVisuals(plr) end
        return
    end

    local viewport = camera.ViewportSize
    local origin = Vector2.new(viewport.X / 2, viewport.Y)
    
    local localRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    local refPos = localRoot and localRoot.Position or camera.CFrame.Position
    local color = ESP.globalColor

    -- Itera sobre o nosso Cache estático em vez de rodar Players:GetPlayers()
    for plr, data in pairs(PlayerCache) do
        local char = data.Character
        local hrp = data.RootPart
        local hum = data.Humanoid

        -- Early Return defensivo: Jogador inválido, descarregado ou morto
        if not char or not char.Parent or hum.Health <= 0 or not hrp or not hrp.Parent then
            clearPlayerVisuals(plr)
            continue
        end

        -- Checagem rápida de distância limite
        local distance = (refPos - hrp.Position).Magnitude
        if distance > ESP.maxDistance then
            clearPlayerVisuals(plr)
            continue
        end

        -- FOV Check básico: Descobre se o jogador está visível na tela
        local hrpPos, onScreen = camera:WorldToViewportPoint(hrp.Position)

        -- 1. Desenho do Highlight (Processado nativamente pela Engine C++)
        if ESP.enabled then
            local hl = ESP.highlights[plr]
            if not hl or hl.Parent ~= char then
                if hl then pcall(function() hl:Destroy() end) end
                hl = Instance.new("Highlight")
                hl.Name = "ESP_H"
                hl.FillTransparency = 0.4
                hl.OutlineTransparency = 0.2
                hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                hl.Parent = char
                ESP.highlights[plr] = hl
            end
            hl.FillColor = color
            hl.OutlineColor = color:Lerp(Color3.new(1,1,1), 0.3)
            hl.Enabled = true
        else
            if ESP.highlights[plr] then pcall(function() ESP.highlights[plr]:Destroy() end); ESP.highlights[plr] = nil end
        end

        -- [OTIMIZAÇÃO CRÍTICA]: Se o jogador não está na tela, pula os cálculos 2D pesados
        if not onScreen then
            if ESP.lines[plr] then ESP.lines[plr].Visible = false end
            local skCache = ESP.skeletons[plr]
            if skCache then for _, l in ipairs(skCache.Lines) do l.Visible = false end end
            continue
        end

        -- 2. Desenho dos Tracers (Linhas)
        if ESP.tracersEnabled then
            local line = ESP.lines[plr]
            if not line then
                line = Drawing.new("Line")
                line.Thickness = 1.5
                line.Transparency = 0.5
                ESP.lines[plr] = line
            end
            line.From = origin
            line.To = Vector2.new(hrpPos.X, hrpPos.Y)
            line.Color = color
            line.Visible = true
        else
            if ESP.lines[plr] then pcall(function() ESP.lines[plr]:Remove() end); ESP.lines[plr] = nil end
        end

        -- 3. Desenho dos Skeletons (Esqueleto estruturado)
        if ESP.skeletonEnabled then
            local skLines = getSkeletonLines(plr, #BoneConnections)
            local lineIndex = 1

            for _, connection in ipairs(BoneConnections) do
                -- Recupera a junta pelo cache interno para poupar chamadas FindFirstChild
                local partA = data.CachedBones[connection[1]]
                if not partA then
                    partA = char:FindFirstChild(connection[1])
                    data.CachedBones[connection[1]] = partA
                end
                
                local partB = data.CachedBones[connection[2]]
                if not partB then
                    partB = char:FindFirstChild(connection[2])
                    data.CachedBones[connection[2]] = partB
                end

                if partA and partB then
                    local posA, onScreenA = camera:WorldToViewportPoint(partA.Position)
                    local posB, onScreenB = camera:WorldToViewportPoint(partB.Position)

                    if onScreenA and onScreenB then
                        local line = skLines[lineIndex]
                        line.From = Vector2.new(posA.X, posA.Y)
                        line.To = Vector2.new(posB.X, posB.Y)
                        line.Color = color
                        line.Visible = true
                        lineIndex = lineIndex + 1
                    end
                end
            end
            -- Oculta as linhas que sobraram no Pool e não foram usadas neste frame
            for i = lineIndex, #skLines do skLines[i].Visible = false end
        else
            if ESP.skeletons[plr] then
                for _, line in ipairs(ESP.skeletons[plr].Lines) do pcall(function() line:Remove() end) end
                ESP.skeletons[plr] = nil
            end
        end
    end
end)

